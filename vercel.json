{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/generate/index.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/{jszip,setimmediate,lie,immediate,pako,readable-stream,abort-controller}/**"
    }
  }
}
