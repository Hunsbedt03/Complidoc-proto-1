{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "doc-builder.js",
      "use": "@vercel/static"
    },
    {
      "src": "api/generate.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/docx/**", "node_modules/jszip/**"]
      }
    }
  ],
  "headers": [
    {
      "source": "/doc-builder.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/doc-builder.js",
      "dest": "/doc-builder.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}