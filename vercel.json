{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/generate.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/docx/**", "node_modules/jszip/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}